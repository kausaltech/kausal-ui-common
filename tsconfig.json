{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./configs/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@common/*": ["./src/*"],
      "@/*": ["../src/*"],
      "@generated/paths/*": ["../src/common/__generated__/paths/*"]
    }
  },
  "include": ["src", "configs/*.mjs", "configs/*.js", "configs/*.ts"]
}
